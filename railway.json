{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -e .",
    "nixpacksSetupCommand": "",
    "startCommand": "gunicorn src.app:app --bind 0.0.0.0:${PORT} --workers 2 --threads 4"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthCheckPath": "/api/health"
  },
  "envVars": {
    "FLASK_ENV": {
      "value": "production"
    },
    "FLASK_DEBUG": {
      "value": "false"
    },
    "LOG_LEVEL": {
      "value": "INFO"
    }
  },
  "port": 8000
}
